# ============================================================
# 1. DATASET
# ============================================================
# folder_lokal = memakai dataset yang sudah ada di laptop/project
# kaggle       = download dari Kaggle, hanya jika ALLOW_KAGGLE_DOWNLOAD=true
SUMBER_DATASET=folder_lokal

# Root folder yang menampung banyak dataset.
DATASET_ROOT=./dataset

# Ganti bagian ini untuk memilih dataset aktif.
DATASET_NAME=banana_ripeness

# Optional override.
FOLDER_LOKAL=./dataset/banana_ripeness

# Digunakan hanya jika SUMBER_DATASET=kaggle.
KAGGLE_DATASET=barkataliarbab/banana-ripeness-classification-classification
KAGGLE_CACHE_DIR=./dataset/_kaggle_cache
ALLOW_KAGGLE_DOWNLOAD=false

# Kosongkan, isi None, atau null jika ingin memakai semua gambar.
MAX_PER_CLASS=None

TRAIN_RATIO=0.60
VAL_RATIO=0.20
TEST_RATIO=0.20

# ============================================================
# 2. PREPROCESSING GAMBAR
# ============================================================
IMAGE_SIZE=256
AUGMENT_TRAIN=true
IMAGE_CHANNELS=3
CROP_FOREGROUND=true
CROP_THRESHOLD=28.0
CROP_MARGIN_RATIO=0.06

# ============================================================
# 3. TRAINING CLASSIFIER
# ============================================================
BATCH_SIZE=8
EPOCHS=30
LEARNING_RATE=0.001
WEIGHT_DECAY=0.0
NUM_WORKERS=2
DEVICE=auto

EARLY_STOPPING=true
EARLY_STOPPING_PATIENCE=5
EARLY_STOPPING_MIN_DELTA=0.001
EARLY_STOPPING_MONITOR=val_loss

# ============================================================
# 4. DOWNSTREAM CLASSIFIER
# ============================================================
# Pilihan: simple_cnn, resnet18, mobilenet_v3_small, efficientnet_b0
PRETRAINED=false
MODEL_NAME=simple_cnn
FREEZE_BACKBONE=false
DROPOUT=0.5

# ============================================================
# 5. CONDITIONAL GAN
# ============================================================
GAN_EPOCHS=180
GAN_LEARNING_RATE_G=0.0001
GAN_LEARNING_RATE_D=0.0001
GAN_WEIGHT_DECAY_G=0.0
GAN_WEIGHT_DECAY_D=0.0
GAN_LATENT_DIM=128
GAN_BASE_CHANNELS=32
GAN_CLASS_EMBEDDING_DIM=32
GAN_MODEL_FILENAME=best_gan.pth
GAN_AUGMENT_TRAIN=true
GAN_EXCLUDE_AUGMENTED=true
GAN_EXCLUDED_AUGMENTATION_TYPES=blur,noise,brightcontrast,clahe,rotate,hflip
GAN_BETA1=0.0
GAN_BETA2=0.9
GAN_LOSS_MODE=wgan_gp
GAN_GP_WEIGHT=5.0
GAN_DRIFT_WEIGHT=0.001
GAN_USE_SPECTRAL_NORM=false
GAN_USE_EDGE_DISCRIMINATOR=true
GAN_EDGE_DISCRIMINATOR_WEIGHT=0.5
GAN_EMA_DECAY=0.995
GAN_LABEL_SMOOTHING=0.1
GAN_FEATURE_MATCH_WEIGHT=0.05
GAN_EDGE_MATCH_WEIGHT=1.0
GAN_AUX_CLASS_WEIGHT=0.5
GAN_DISC_STEPS=2
GAN_EARLY_STOPPING=false
GAN_MIN_CHECKPOINT_EPOCH=30
GAN_PREVIEW_EVERY=5
GAN_PREVIEW_GRID_COUNT=16
GAN_PER_CLASS=true
GAN_MODELS_DIRNAME=classwise_gans

# ============================================================
# 6. GENERASI SINTETIS
# ============================================================
GENERATED_IMAGES_PER_CLASS=100
GAN_NOISE_SCALE=1.0
SYNTHETIC_OUTPUT_DIRNAME=generate_synthetic_image
EMBEDDING_VIS_MAX_POINTS=1500
GAN_PREVIEW_COUNT=8

# ============================================================
# 7. OUTPUT
# ============================================================
OUTPUT_DIR=outputs_retina_contour256
MODEL_FILENAME=best_model.pth
SEED=42
